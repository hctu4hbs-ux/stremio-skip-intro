# ─── Server ──────────────────────────────────────────────
PORT=7000
NODE_ENV=development

# ─── GitHub ──────────────────────────────────────────────
# Personal Access Token with repo scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Target repository for publishing catalog.json
GITHUB_REPO_OWNER=your-username
GITHUB_REPO_NAME=your-repo
GITHUB_BRANCH=main
GITHUB_FILE_PATH=data/catalog.json

# ─── AniSkip Integration (optional) ──────────────────────
# https://aniskip.com — fetch anime timestamps automatically
ANISKIP_ENABLED=true

# ─── Data ────────────────────────────────────────────────
# Where to store the local catalog on disk
DATA_DIR=./data
