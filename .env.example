# ─── Server ──────────────────────────────────────────────────────────────────
PORT=7000
NODE_ENV=development

# Public URL of this server — required so proxy and VTT links work from
# any device, not just localhost. Set this when deploying.
BASE_URL=http://localhost:7000

# ─── HLS Proxy — Automatic Skip (no button) ──────────────────────────────────
# Point this at any Stremio add-on that provides HLS streams.
# stremio-skip-intro fetches streams from that add-on, wraps every HLS stream
# through the local proxy (intros physically removed), and returns the result
# to Stremio. The player never loads a single intro frame.
#
# Examples:
#   Torrentio (most popular, free):
#     UPSTREAM_ADDON_URL=https://torrentio.strem.fun/sort=qualitysize
#
#   Cinemeta streams (if available):
#     UPSTREAM_ADDON_URL=https://v3-cinemeta.strem.io
#
#   Your own add-on:
#     UPSTREAM_ADDON_URL=https://my-addon.example.com
#
# Leave empty to disable the stream handler. The skip-button subtitle
# fallback remains active regardless.
UPSTREAM_ADDON_URL=

# ─── AniSkip (optional) ───────────────────────────────────────────────────────
# Enable automatic anime timestamps from aniskip.com
ANISKIP_ENABLED=true

# Map an IMDB ID to a MyAnimeList ID for better AniSkip results:
# MAL_tt0000000=12345

# ─── Data ─────────────────────────────────────────────────────────────────────
DATA_DIR=./data
